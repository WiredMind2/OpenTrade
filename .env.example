# Copy this file to `.env` and fill values. Do NOT commit your real `.env` to git.

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# NewsAPI (free tier) key
NEWSAPI_KEY=your_newsapi_key_here

# (Optional) Kaggle credentials if you want to automate downloads using the kaggle CLI
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# Database path (relative to repo root)
DB_PATH=data/backtest.db

# Optional runtime overrides
INITIAL_CAPITAL=100000
COMMISSION_PER_SHARE=0.005
SLIPPAGE_PCT=0.0002
